datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUMS
// ==========================================

enum PlatformRole {
  USER
  RECRUITER
  ADMIN
  SYSTEM
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

enum SubscriptionTier {
  FREE
  PRO
  ENTERPRISE
}

enum ApplicationStatus {
  WISHLIST
  APPLIED
  INTERVIEWING
  OFFER
  REJECTED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  AUTHENTICATE
  DOWNLOAD
}

enum NotificationChannel {
  EMAIL
  IN_APP
  SLACK
  DISCORD
}

// ==========================================
// IDENTITY & MEMBERSHIPS
// ==========================================

model User {
  id            String             @id @default(uuid())
  email         String             @unique
  name          String?
  image         String?
  passwordHash  String?            // Null for OAuth logins
  role          PlatformRole       @default(USER)
  tier          SubscriptionTier   @default(FREE)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?          // Soft deletes

  accounts      Account[]
  sessions      Session[]
  memberships   OrgMembership[]
  resumes       Resume[]
  applications  JobApplication[]
  portfolios    Portfolio[]
  recruiter     RecruiterProfile?
  auditLogs     SystemAuditLog[]
  aiLogs        AIRequestLog[]
  notifications UserNotification[]
  conversations Conversation[]
  suggestionLogs AISuggestionLog[]
  jobs          JobDescription[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(uuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id          String          @id @default(uuid())
  name        String
  slug        String          @unique
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?       // Soft deletes

  memberships OrgMembership[]
}

model OrgMembership {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  role           OrgRole      @default(MEMBER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

// ==========================================
// RESUME ENGINE (CANVAS DATA MODELS)
// ==========================================

model Resume {
  id           String          @id @default(uuid())
  userId       String
  title        String          @default("My Resume")
  language     String          @default("en")
  themeColor   String          @default("#171717")
  fontFamily   String          @default("Inter")
  fontSize     Int             @default(11)
  documentSize String          @default("Letter")
  spacing      Float           @default(1.0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?       // Soft deletes

  profile      Profile?
  workHistory  WorkExperience[]
  education    Education[]
  projects     Project[]
  skills       Skill[]
  customs      CustomSection[]
  versions     ResumeVersion[]
  atsReports   ATSReport[]
  shortlists   ShortlistEntry[]
  jobLinks     ResumeJobLink[]

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResumeVersion {
  id          String   @id @default(uuid())
  resumeId    String
  versionName String
  snapshot    Json     // Encapsulated state of profile, work, edu, skills, customs
  createdAt   DateTime @default(now())

  resume      Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model Profile {
  id        String  @id @default(uuid())
  resumeId  String  @unique
  name      String  @default("")
  email     String  @default("")
  phone     String  @default("")
  location  String  @default("")
  url       String  @default("")
  summary   String  @db.Text

  resume    Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model WorkExperience {
  id           String    @id @default(uuid())
  resumeId     String
  company      String
  position     String
  location     String?
  startDate    String
  endDate      String?
  current      Boolean   @default(false)
  descriptions String[]
  orderIndex   Int       @default(0)

  resume       Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model Education {
  id           String   @id @default(uuid())
  resumeId     String
  school       String
  degree       String
  fieldOfStudy String?
  location     String?
  startDate    String
  endDate      String
  gpa          String?
  descriptions String[]
  orderIndex   Int      @default(0)

  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model Project {
  id           String   @id @default(uuid())
  resumeId     String
  name         String
  role         String?
  url          String?
  startDate    String?
  endDate      String?
  descriptions String[]
  orderIndex   Int      @default(0)

  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model Skill {
  id         String   @id @default(uuid())
  resumeId   String
  name       String
  level      Int      @default(3) // 1-5 rating
  category   String?
  orderIndex Int      @default(0)

  resume     Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model CustomSection {
  id           String   @id @default(uuid())
  resumeId     String
  heading      String   @default("Custom Section")
  descriptions String[]
  orderIndex   Int      @default(0)

  resume       Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

// ==========================================
// JOB APPLICATIONS TRACKER (CRM)
// ==========================================

model JobApplication {
  id             String            @id @default(uuid())
  userId         String
  company        String
  title          String
  salary         String?
  location       String?
  status         ApplicationStatus @default(WISHLIST)
  url            String?
  notes          String?           @db.Text
  appliedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?         // Soft deletes

  interviews     Interview[]
  contacts       JobContact[]

  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Interview {
  id               String         @id @default(uuid())
  jobApplicationId String
  stageName        String         // Phone Screen, Technical, Hiring Manager
  scheduledAt      DateTime
  durationMinutes  Int            @default(60)
  notes            String?        @db.Text
  createdAt        DateTime       @default(now())

  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
}

model JobContact {
  id               String         @id @default(uuid())
  jobApplicationId String
  name             String
  email            String?
  phone            String?
  role             String?        // Recruiter, Hiring Manager
  createdAt        DateTime       @default(now())

  jobApplication   JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
}

// ==========================================
// PORTFOLIO GENERATOR
// ==========================================

model Portfolio {
  id          String             @id @default(uuid())
  userId      String
  subdomain   String             @unique
  customDomain String?           @unique
  theme       String             @default("minimalist")
  published   Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?          // Soft deletes

  analytics   PortfolioAnalytics[]
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PortfolioAnalytics {
  id          String    @id @default(uuid())
  portfolioId String
  visitorIp   String?
  userAgent   String?
  referrer    String?
  event       String    @default("VIEW") // VIEW, DOWNLOAD
  createdAt   DateTime  @default(now())

  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
}

// ==========================================
// RECRUITER & SOURCING PORTAL
// ==========================================

model RecruiterProfile {
  id          String           @id @default(uuid())
  userId      String           @unique
  companyName String
  approved    Boolean          @default(false)
  createdAt   DateTime         @default(now())

  shortlists  Shortlist[]
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Shortlist {
  id                 String           @id @default(uuid())
  recruiterProfileId String
  name               String
  description        String?
  createdAt          DateTime         @default(now())

  entries            ShortlistEntry[]
  recruiter          RecruiterProfile @relation(fields: [recruiterProfileId], references: [id], onDelete: Cascade)
}

model ShortlistEntry {
  id          String    @id @default(uuid())
  shortlistId String
  resumeId    String
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())

  shortlist   Shortlist @relation(fields: [shortlistId], references: [id], onDelete: Cascade)
  resume      Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([shortlistId, resumeId])
}

// ==========================================
// SYSTEM INFRASTRUCTURE (AUDIT, AI, CONFIG)
// ==========================================

model SystemAuditLog {
  id         String       @id @default(uuid())
  userId     String?
  action     AuditAction
  tableName  String
  recordId   String
  metadata   Json?        // Stores old and new payload states
  ipAddress  String?
  createdAt  DateTime     @default(now())

  user       User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AIRequestLog {
  id            String   @id @default(uuid())
  userId        String
  provider      String
  model         String
  tokensSent    Int
  tokensRecv    Int
  latencyMs     Int
  purpose       String   // BulletRewrite, CoverLetter, Parsing
  promptVersion String   @default("v1")
  success       Boolean
  errorDetails  String?  @db.Text
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ATSReport {
  id                    String          @id @default(uuid())
  resumeId              String
  jobDescriptionId      String?
  overallScore          Int             @default(0)
  keywordScore          Int             @default(0)
  semanticScore          Int             @default(0)
  experienceScore       Int             @default(0)
  projectScore          Int             @default(0)
  educationScore        Int             @default(0)
  qualityScore          Int             @default(0)
  reasoning             String          @db.Text
  matchedKeywords       String[]
  missingKeywords       String[]
  improvementSuggestions Json            // List of { suggestion: string, category: string, estimatedScoreGain: number }
  createdAt             DateTime        @default(now())

  resume                Resume          @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  job                   JobDescription? @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade)
}

model UserNotification {
  id          String              @id @default(uuid())
  userId      String
  channel     NotificationChannel @default(IN_APP)
  title       String
  content     String
  read        Boolean             @default(false)
  createdAt   DateTime            @default(now())

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Template {
  id          String   @id @default(uuid())
  name        String   @unique
  description String
  previewUrl  String
  category    String
  premium     Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  description String
  active      Boolean  @default(false)
  usersRule   String[] // Array of user emails explicitly whitelisted for beta tests
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Conversation {
  id        String    @id @default(uuid())
  userId    String
  title     String    @default("New Chat")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  role           String
  content        String       @db.Text
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model AISuggestionLog {
  id             String           @id @default(uuid())
  userId         String
  promptId       String
  suggestionText String           @db.Text
  explanation    String           @db.Text
  expectedBenefit String          @db.Text
  confidenceScore Float
  atsImpact      Float
  category       String
  state          SuggestionState  @default(PENDING)
  feedback       FeedbackState    @default(NONE)
  tokensUsed     Int              @default(0)
  responseTimeMs Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SuggestionState {
  PENDING
  ACCEPTED
  REJECTED
}

enum FeedbackState {
  NONE
  HELPFUL
  NOT_HELPFUL
}

enum JobStatusCollection {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
  ARCHIVED
}

model JobDescription {
  id              String              @id @default(uuid())
  userId          String
  title           String
  company         String
  description     String              @db.Text
  industry        String?
  remoteType      String?
  salaryMin       Float?
  salaryMax       Float?
  seniority       String?
  techStack       String[]
  hiringFocus     String?
  matchScore      Float?
  statusCollection JobStatusCollection @default(SAVED)
  
  matchedKeywords String[]
  weakKeywords    String[]
  missingKeywords String[]

  matchedSkills   String[]
  missingSkills   String[]
  suggestedSkills String[]
  learningRecommendations String[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeLinks     ResumeJobLink[]
  atsReports      ATSReport[]
}

model ResumeJobLink {
  id               String         @id @default(uuid())
  resumeId         String
  jobDescriptionId String
  createdAt        DateTime       @default(now())

  resume           Resume         @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobDescription   JobDescription @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade)

  @@unique([resumeId, jobDescriptionId])
}
