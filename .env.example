# ==========================================
# RESUMEFLOW ENV CONFIGURATION TEMPLATE
# ==========================================

# 1. API & Network Settings
NEXT_PUBLIC_API_URL=http://localhost:3001
PORT=3000

# 2. Database & Cache
# Local development Postgres and Redis default configurations
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resumeflow?schema=public
REDIS_URL=redis://localhost:6379

# 3. Security & Authentication
# NextAuth / Auth.js configuration keys
NEXTAUTH_SECRET=generate-a-secure-random-key-for-production
NEXTAUTH_URL=http://localhost:3000

# 4. AI Provider Gateway Switchboard
# Default: Local LM Studio. Options: lm-studio | gemini | openai | anthropic
AI_PROVIDER=lm-studio
AI_ENDPOINT=http://localhost:1234/v1
AI_MODEL_NAME=meta-llama-3-8b-instruct
AI_API_KEY=not-needed-for-lm-studio
AI_MAX_RETRIES=3
